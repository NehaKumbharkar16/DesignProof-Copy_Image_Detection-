# DesignProof AI Service Configuration

# Server
FASTAPI_ENV=development
UVICORN_HOST=0.0.0.0
UVICORN_PORT=8000
WORKERS=4

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/designproof_db

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=1

# API Keys
BACKEND_API_KEY=your_backend_api_key
BACKEND_API_URL=http://localhost:5000

# Image Processing
TEMP_IMAGE_STORAGE=/tmp/designproof_images
MAX_IMAGE_SIZE=52428800
IMAGE_QUALITY=95
THUMBNAIL_SIZE=512

# AI Models
MODEL_NAME=resnet50
MODEL_PATH=/models/resnet50_weights.pth
USE_GPU=true
DEVICE=cuda

# Image Similarity Detection
SIMILARITY_THRESHOLD=0.7
BATCH_SIZE=16
FEATURE_VECTOR_SIZE=2048

# Reverse Image Search
GOOGLE_IMAGES_ENABLED=true
BING_IMAGES_ENABLED=false
YANDEX_IMAGES_ENABLED=false

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Celery (Background Tasks)
CELERY_BROKER_URL=redis://localhost:6379/2
CELERY_RESULT_BACKEND=redis://localhost:6379/2
CELERY_TASK_TIME_LIMIT=3600

# Security
ALGORITHM=HS256
SECRET_KEY=your_super_secret_ai_key

# Feature Detection
ENABLE_COLOR_VARIATION=true
ENABLE_BACKGROUND_DETECTION=true
ENABLE_FACE_DETECTION=true
ENABLE_OCR=false
