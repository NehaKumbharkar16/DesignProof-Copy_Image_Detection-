# DesignProof Frontend Configuration

# API
VITE_API_BASE_URL=http://localhost:5000
VITE_API_TIMEOUT=30000

# Authentication
VITE_JWT_KEY=designproof_jwt

# Environment
VITE_ENV=development

# Feature Flags
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_SENTRY=false
VITE_ENABLE_HOTJAR=false

# Stripe (Optional)
VITE_STRIPE_PUBLIC_KEY=pk_test_your_stripe_key

# Google Analytics
VITE_GOOGLE_ANALYTICS_ID=UA-XXXXXXXXX-X

# AWS S3
VITE_AWS_S3_BUCKET=designproof-images
VITE_AWS_S3_REGION=us-east-1

# Image Processing
VITE_MAX_IMAGE_SIZE=52428800
VITE_ALLOWED_IMAGE_FORMATS=jpg,jpeg,png,gif,webp

# UI
VITE_ITEMS_PER_PAGE=20
VITE_THEME=dark
